function updateWellnessScore(){
  const stepScore=Math.min(30,(HD.steps/STEP_GOAL)*30);
  const hrScore=HD.hr<100&&HD.hr>50?Math.max(0,25-(Math.abs(HD.hr-70)/3)):10;
  const sleepScore=Math.min(25,(HD.sleep/SLEEP_GOAL)*25);
  const waterScore=Math.min(10,(HD.water/WATER_GOAL)*10);
  const moodScore={'😄':10,'🙂':8,'😐':5,'😔':3,'😤':2,'😴':4}[HD.mood]||5;
  const score=Math.round(Math.min(100,stepScore+hrScore+sleepScore+waterScore+moodScore));
  const el=$('wellnessScore'); if(el)el.textContent=score;
  const bar=$('wellnessBar'); if(bar)bar.style.width=score+'%';
  // Ring
  const ring=$('scoreCircle');
  if(ring){const dash=263.9;const offset=dash-(dash*(score/100));ring.style.strokeDashoffset=offset;ring.style.stroke=score>=75?'var(--forest)':score>=50?'var(--amber)':'var(--red)';}
  // Metrics
  const sm=$('scoreSteps');if(sm)sm.textContent=HD.steps.toLocaleString();
  const sh=$('scoreHR');if(sh)sh.textContent=HD.hr+' bpm';
  const ss=$('scoreSleep');if(ss)ss.textContent=HD.sleep+'h';
  const smd=$('scoreMood');if(smd)smd.textContent=HD.mood;
  return score;
}

function renderAlertBanners(){
  const el=$('alertBanners');if(!el)return;

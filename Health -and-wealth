  if(HD.water<4) risks.push({level:'low',icon:'💧',text:'Dehydration risk — drink more water today'});
  if(HD.hr>90) risks.push({level:'high',icon:'❤️',text:'Elevated resting HR — schedule a check-up if persistent'});
  if(risks.length===0) risks.push({level:'good',icon:'🌟',text:'No significant risks detected. Keep up your healthy habits!'});
  el.innerHTML=risks.map(r=>`<div class="alert-banner ${r.level==='high'?'ab-warning':r.level==='medium'?'ab-stress':r.level==='good'?'ab-success':'ab-info'}"><span class="ab-ico">${r.icon}</span><div>${r.text}</div></div>`).join('');
}


  if(HD.sleep<6) html+=`<div class="alert-banner ab-warning"><span class="ab-ico">😴</span><div><b>Poor Sleep Pattern</b><br/>Only ${HD.sleep}h last night. Aim for 7-9 hours for optimal health.</div></div>`;
  // Low steps
  if(HD.steps<2000) html+=`<div class="alert-banner ab-info"><span class="ab-ico">👣</span><div><b>Move More Today</b><br/>Only ${HD.steps} steps. Take a 10-min walk to boost energy.</div></div>`;
  // Good day
  if(HD.steps>=STEP_GOAL&&HD.sleep>=7&&HD.hr<85) html+=`<div class="alert-banner ab-success"><span class="ab-ico">🌟</span><div><b>Great Health Day!</b><br/>All vitals look good. Keep it up!</div></div>`;
  el.innerHTML=html;
}

function renderStreakRow(){
  const el=$('streakRow');if(!el)return;
  const days=['M','T','W','T','F','S','S'];
  const today=new Date().getDay();
  let html='';
  for(let i=0;i<7;i++){
    const isToday=i===(today===0?6:today-1);
    const isDone=i<(HD.streak%7);
    html+=`<div class="streak-dot ${isToday?'sd-today':isDone?'sd-done':'sd-future'}">${days[i]}</div>`;
  }
  const sc=$('streakCount');if(sc)sc.textContent=HD.streak;
  el.innerHTML=html;
}

function checkStreak(){
  const today=new Date().toDateString();
  if(HD.lastActive!==today){
    const yesterday=new Date(Date.now()-86400000).toDateString();
    if(HD.lastActive===yesterday){HD.streak++;} else if(HD.lastActive!==today){HD.streak=HD.streak>0?HD.streak:0;}
    HD.lastActive=today;
    saveHD();
  }
}


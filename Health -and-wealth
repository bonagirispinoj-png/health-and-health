function initFirstAid(){renderFirstAid();renderHomeRemedies();renderHealthTips();renderBloodGroup();}

const FIRST_AID=[{ico:'🤕',title:'Head Injury / Concussion',color:'var(--red2)',steps:['Keep person still and calm','Check for loss of consciousness','Apply cold pack to swelling','Do NOT move if spine injury suspected','Call 112 immediately for severe cases']},{ico:'🔥',title:'Burns',color:'#fff7ed',steps:['Cool with running cold water for 10-20 mins','Do NOT use ice or butter','Cover loosely with clean cloth','Do NOT burst blisters','Seek medical help for large burns']},{ico:'🩸',title:'Bleeding Control',color:'var(--red2)',steps:['Apply firm pressure with clean cloth','Elevate the injured limb above heart','Do NOT remove embedded objects','Keep pressing — do not release','Call 112 if bleeding is severe']},{ico:'😮‍💨',title:'Choking (Adult)',color:'var(--amber2)',steps:['Ask "Are you choking?" — if yes, act','Stand behind, lean forward','Give 5 firm back blows between shoulder blades','Give 5 abdominal thrusts (Heimlich)','Repeat until object dislodges','Call 112 if unconscious']},{ico:'💊',title:'Drug / Poison Overdose',color:'var(--purple2)',steps:['Call Poison Control: 1800-11-4433','Keep person awake and talking','Do NOT induce vomiting unless told to','Collect medication/substance for responders','Call 112 for severe symptoms']},{ico:'😵',title:'Fainting / Unconscious',color:var('--blue2'),steps:['Lay person on back, elevate legs','Loosen tight clothing','Check breathing','Do NOT give food/water','Recovery position if breathing normally','Call 112 if not recovering in 1 minute']}];

function renderFirstAid(){
  const el=$('firstAidList');if(!el)return;
  el.innerHTML=FIRST_AID.map((fa,i)=>`<div class="firstaid-card"><div class="fa-header" onclick="toggleFA('fa${i}')"><div class="fa-ico" style="background:${fa.color};">${fa.ico}</div><div class="fa-title">${fa.title}</div><div class="fa-arrow" id="faa${i}">▼</div></div><div class="fa-body" id="fa${i}">${fa.steps.map((s,j)=>`<div style="padding:4px 0;border-bottom:1px solid var(--bdr);font-size:.79rem;">${j+1}. ${s}</div>`).join('')}</div></div>`).join('');
}

function toggleFA(id){const el=$(id);const arrow=$('faa'+id.replace('fa',''));if(el.classList.contains('open')){el.classList.remove('open');if(arrow)arrow.textContent='▼';}else{el.classList.add('open');if(arrow)arrow.textContent='▲';}}

const HOME_REMEDIES=[{ico:'🤧',condition:'Common Cold',remedy:'Ginger + honey + tulsi tea, steam inhalation, turmeric milk before sleep'},{ico:'🤢',condition:'Nausea / Upset Stomach',remedy:'Ginger tea, jeera water, light rice kanji. Avoid heavy/spicy food.'},{ico:'🤯',condition:'Headache',remedy:'Cold compress, peppermint oil on temples, ginger tea, adequate hydration'},{ico:'😮‍💨',condition:'Cough',remedy:'Honey + ginger + black pepper tea. Steam inhalation with eucalyptus.'},{ico:'🦟',condition:'Mosquito Bites',remedy:'Neem leaves paste, turmeric paste, aloe vera gel application'},{ico:'🤕',condition:'Joint / Knee Pain',remedy:'Warm compress, turmeric milk, light stretching. Consult doctor if severe.'},{ico:'😴',condition:'Insomnia / Poor Sleep',remedy:'Warm milk with nutmeg, chamomile tea, avoid screens 1 hour before bed'},{ico:'🩸',condition:'High Blood Pressure',remedy:'Garlic daily, amla juice, reduce salt, regular walking 30 mins'}];

function renderHomeRemedies(){
  const el=$('homeRemediesList');if(!el)return;
  el.innerHTML=HOME_REMEDIES.map((r,i)=>`<div class="firstaid-card"><div class="fa-header" onclick="toggleFA('hr${i}')"><div class="fa-ico" style="background:var(--green2);">${r.ico}</div><div class="fa-title">${r.condition}</div><div class="fa-arrow" id="hraa${i}">▼</div></div><div class="fa-body" id="hr${i}"><div style="font-size:.8rem;color:var(--txt3);line-height:1.6;">🌿 <b>Remedy:</b> ${r.remedy}<br/><span style="color:var(--amber);font-size:.74rem;">⚠️ Consult a doctor if symptoms persist or worsen.</span></div></div></div>`).join('');
  // Fix toggleFA for home remedies
  document.querySelectorAll('[id^="hraa"]').forEach((el,i)=>{el.id='faa'+'hr'+i;});
  document.querySelectorAll('[id^="hr"]').forEach((el,i)=>{if(!el.id.includes('hraa'))el.id='fa'+'hr'+i;});
}


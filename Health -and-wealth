  el.innerHTML=behaviors.map(b=>`<div style="padding:10px;background:var(--bg2);border-radius:10px;margin-bottom:7px;font-size:.8rem;"><div><b>Trigger:</b> ${b.trigger} → ${b.behavior}</div><div style="color:var(--forest);font-weight:600;margin-top:4px;">🤖 AI: ${b.intervention}</div></div>`).join('');
}

// ── GPS & NEARBY ──────────────────────────────────────────────────────
function getLocation(){
  const el=$('locationStatus');
  if(!navigator.geolocation){if(el)el.innerHTML='<div class="alert alert-w"><span>📍</span><span>GPS not available on this device</span></div>';renderNearbyPlaces(null,null);return;}
  navigator.geolocation.getCurrentPosition(pos=>{
    userLat=pos.coords.latitude;userLng=pos.coords.longitude;
    if(el)el.innerHTML=`<div class="alert alert-s"><span>📍</span><span>Location found: ${userLat.toFixed(4)}, ${userLng.toFixed(4)}</span></div>`;
    renderNearbyPlaces(userLat,userLng);
    renderGeoHealth();
  },err=>{
    if(el)el.innerHTML='<div class="alert alert-w"><span>📍</span><span>Location access denied. Showing sample nearby places.</span></div>';
    renderNearbyPlaces(null,null);
  },{timeout:8000,enableHighAccuracy:true});
}

function initNearby(){if(!userLat)getLocation();else{renderNearbyPlaces(userLat,userLng);renderGeoHealth();}}

function renderNearbyPlaces(lat,lng){
  const hospitals=[{name:'Apollo Hospital',dist:'0.8 km',time:'5 min',open:true,type:'Multi-specialty'},{name:'AIIMS Emergency',dist:'1.2 km',time:'8 min',open:true,type:'Government'},{name:'Yashoda Hospital',dist:'2.1 km',time:'12 min',open:true,type:'Multi-specialty'},{name:'Govt Primary Health Center',dist:'0.5 km',time:'3 min',open:true,type:'Primary Care'}];
  const pharmacies=[{name:'MedPlus Pharmacy',dist:'0.3 km',time:'2 min',open:true},{name:'Apollo Pharmacy',dist:'0.6 km',time:'4 min',open:true},{name:'Medkart Pharmacy',dist:'1.0 km',time:'6 min',open:false},{name:'Jan Aushadhi Center',dist:'0.4 km',time:'3 min',open:true}];
  const hel=$('hospitalList'),pel=$('pharmacyList');
  if(hel)hel.innerHTML=hospitals.map(h=>`<div class="place-card" onclick="openMaps('hospital')"><div class="place-ico place-hosp">🏥</div><div><div class="place-name">${h.name}</div><div class="place-dist">${h.dist} · ${h.time} · ${h.type}</div></div><div class="place-open ${h.open?'po-open':'po-closed'}">${h.open?'Open':'Closed'}</div></div>`).join('');
  if(pel)pel.innerHTML=pharmacies.map(p=>`<div class="place-card" onclick="openMaps('pharmacy')"><div class="place-ico place-pharm">💊</div><div><div class="place-name">${p.name}</div><div class="place-dist">${p.dist} · ${p.time}</div></div><div class="place-open ${p.open?'po-open':'po-closed'}">${p.open?'Open':'Closed'}</div></div>`).join('');
}

function openMaps(type){
  const q=type==='hospital'?'hospital near me':'pharmacy near me';
  const url=userLat?`https://www.google.com/maps/search/${q}/@${userLat},${userLng},14z`:`https://www.google.com/maps/search/${q}`;
  window.open(url,'_blank');
}

function renderGeoHealth(){
  const el=$('geoHealth');if(!el)return;
  el.innerHTML=`
    <div class="alert-banner ab-info"><span class="ab-ico">🌆</span><div><b>Urban area detected</b><br/>Higher pollution risk. Use N95 mask on dusty days. Check AQI before outdoor exercise.</div></div>
    <div class="alert-banner ab-success" style="margin-top:8px;"><span class="ab-ico">🌡️</span><div><b>Climate tip</b><br/>Hydrate extra in warm weather. Drink water before feeling thirsty.</div></div>`;
}

function triggerSOS(){
  const confirmed=confirm('🆘 EMERGENCY SOS\n\nThis will call emergency services (112) and share your location.\n\nConfirm only in real emergency!');
  if(!confirmed)return;
  toast('🆘 SOS activated! Calling 112...',5000);
  const msg=userLat?`Emergency! Location: ${userLat.toFixed(4)},${userLng.toFixed(4)} — Need help!`:'Emergency! Need immediate medical help!';
  // Attempt to call 112
  window.location.href='tel:112';
  // Also try WhatsApp emergency
  setTimeout(()=>{if(navigator.share){navigator.share({title:'EMERGENCY SOS',text:msg});}},2000);
}

// GUARDIAN MODE
let guardianInterval=null;
function toggleGuardian(){
  HD.guardianMode=!HD.guardianMode;
  localStorage.setItem('hiw_guardian',HD.guardianMode.toString());
  const btn=$('guardianBtn');const el=$('guardianMode');
  if(HD.guardianMode){
    if(btn){btn.textContent='Disable Guardian Mode';btn.classList.add('btn-red');btn.classList.remove('btn-primary');}
    if(el)el.innerHTML='<div class="alert alert-s"><span>🛡️</span><span>Health Guardian Mode ACTIVE. Monitoring HR, activity and stress patterns every 5 minutes. Alert will be sent if anomaly detected.</span></div>';
    guardianInterval=setInterval(()=>{if(HD.hr>100||HD.sleep<4){toast('🛡️ Health Guardian: Anomaly detected! Check your vitals.',6000);}},300000);
    toast('🛡️ Guardian Mode activated!');
  }else{
    clearInterval(guardianInterval);
    if(btn){btn.textContent='Enable Guardian Mode';btn.classList.remove('btn-red');btn.classList.add('btn-primary');}
    if(el)el.innerHTML='<div class="alert alert-i"><span>🛡️</span><span>Guardian Mode is OFF. Enable to auto-monitor your health and get alerts.</span></div>';
    toast('Guardian Mode disabled');
  }
}

// ── RECORDS ───────────────────────────────────────────────────────────
function initRecords(){renderHealthProfile();renderHealthRecords();renderWeeklySummary();renderMicroClimate();}

function renderHealthProfile(){
  const el=$('healthProfile');if(!el)return;
  const name=CD?.name||'User';
  const blood=CD?.bloodGroup||localStorage.getItem('hiw_blood')||'Unknown';
  const items=[{ico:'👤',lbl:'Name',val:name},{ico:'🩸',lbl:'Blood Group',val:blood},{ico:'❤️',lbl:'Resting HR',val:HD.hr+' bpm'},{ico:'👣',lbl:'Today Steps',val:HD.steps.toLocaleString()},{ico:'🌙',lbl:'Last Sleep',val:HD.sleep+'h'},{ico:'💧',lbl:'Water Today',val:HD.water+' glasses'}];
  el.innerHTML=items.map(i=>`<div style="background:var(--bg2);border-radius:10px;padding:11px;text-align:center;"><div style="font-size:1.2rem;margin-bottom:3px;">${i.ico}</div><div style="font-weight:700;font-size:.86rem;color:var(--txt);">${i.val}</div><div style="font-size:.65rem;color:var(--txt4);margin-top:1px;">${i.lbl}</div></div>`).join('');
}

function renderHealthRecords(){
  const el=$('healthRecords');if(!el)return;
  const records=JSON.parse(localStorage.getItem('hiw_records')||'[]');
  if(!records.length){el.innerHTML='<div class="empty"><div class="empty-ico">📋</div><div class="empty-title">No records yet</div><div style="font-size:.8rem;color:var(--txt4);">Add blood pressure, sugar readings, doctor visits etc.</div></div>';return;}
  el.innerHTML=records.slice(-5).reverse().map(r=>`<div style="padding:9px 0;border-bottom:1px solid var(--bdr);font-size:.82rem;"><div style="font-weight:600;">${r.type}</div><div style="color:var(--txt3);">${r.value} · ${r.date}</div></div>`).join('');
}

function showAddRecord(){
  const type=prompt('Record type (e.g. Blood Pressure, Blood Sugar, Weight):');
  if(!type)return;
  const value=prompt(`Enter value for ${type}:`);
  if(!value)return;
  const records=JSON.parse(localStorage.getItem('hiw_records')||'[]');
  records.push({type:stripJS(type),value:stripJS(value),date:new Date().toLocaleDateString('en-IN')});
  localStorage.setItem('hiw_records',JSON.stringify(records));
  renderHealthRecords();
  toast('Record saved!');
}

function renderWeeklySummary(){
  const el=$('weeklySummary');if(!el)return;
  const avgSteps=Math.round(HD.stepsHistory.slice(-7).reduce((a,b)=>a+b,0)/7);
  const avgSleep=(HD.sleepHistory.slice(-7).reduce((a,b)=>a+b,0)/7).toFixed(1);
  const avgHR=Math.round(HD.hrHistory.slice(-7).reduce((a,b)=>a+b,0)/7);
  el.innerHTML=`
    <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:8px;">
      <div style="background:var(--bg2);border-radius:10px;padding:10px;text-align:center;"><div style="font-weight:700;font-size:1rem;color:var(--forest);">${avgSteps.toLocaleString()}</div><div style="font-size:.65rem;color:var(--txt4);">Avg Steps</div></div>
      <div style="background:var(--bg2);border-radius:10px;padding:10px;text-align:center;"><div style="font-weight:700;font-size:1rem;color:var(--purple);">${avgSleep}h</div><div style="font-size:.65rem;color:var(--txt4);">Avg Sleep</div></div>
      <div style="background:var(--bg2);border-radius:10px;padding:10px;text-align:center;"><div style="font-weight:700;font-size:1rem;color:var(--red);">${avgHR}</div><div style="font-size:.65rem;color:var(--txt4);">Avg HR bpm</div></div>
    </div>
    <div style="margin-top:10px;font-size:.8rem;color:var(--txt3);text-align:center;">7-day averages · ${avgSteps>=STEP_GOAL?'✅ Step goal met':'⚠️ Below step goal'} · ${parseFloat(avgSleep)>=7?'✅ Good sleep':'⚠️ Improve sleep'}</div>`;
}

function renderMicroClimate(){
  const el=$('microClimate');if(!el)return;
  const hour=new Date().getHours();
  const advice=hour<10?'Morning: Good for outdoor exercise. UV index low. Air quality best before 9 AM.':hour<14?'Afternoon: High UV. Avoid outdoor exercise 11 AM–3 PM. Stay hydrated.':hour<18?'Evening: Good for walking. Reduce pollution exposure by wearing a mask near traffic.':'Night: Cool temperature. Good for light walk. Avoid heavy meals after 8 PM.';
  el.innerHTML=`<div class="alert-banner ab-info"><span class="ab-ico">🌡️</span><div><b>Current time health tip</b><br/>${advice}</div></div>`;
}

